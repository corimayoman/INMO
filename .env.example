# ─── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:4000

# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://wpf:wpf_secret@localhost:5432/worldpropertyfinder

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Elasticsearch ─────────────────────────────────────────────────────────────
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=changeme

# ─── Auth / JWT ────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret_min_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_this_refresh_secret_too
JWT_REFRESH_EXPIRES_IN=30d

# ─── OAuth Providers ───────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# ─── S3 / Storage ──────────────────────────────────────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=worldpropertyfinder
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
CDN_URL=http://localhost:9000/worldpropertyfinder

# ─── Maps ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_MAPBOX_TOKEN=
GOOGLE_MAPS_API_KEY=

# ─── AI ────────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ─── Email ─────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.mailgun.org
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@worldpropertyfinder.com

# ─── SMS ───────────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ─── Payments ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ─── Rate Limiting ─────────────────────────────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ─── Ingestion ─────────────────────────────────────────────────────────────────
INGESTION_CRON_SCHEDULE=0 */6 * * *
INGESTION_BATCH_SIZE=100
INGESTION_MAX_RETRIES=3

# ─── Feature Flags ─────────────────────────────────────────────────────────────
FEATURE_AI_SEARCH=true
FEATURE_VIRTUAL_TOURS=true
FEATURE_MORTGAGE_CALC=true
